# 只在后端保存 API Key，不要写进前端，也不要提交到 git。

# DeepSeek 作为默认云模型提供方
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 聊天/RAG 可继续单独配置
CHAT_MODEL=deepseek-v4-flash

# 文本补全单独走 completion 配置
COMPLETION_PROVIDER=deepseek
COMPLETION_MODEL=deepseek-v4-flash
COMPLETION_FALLBACK_ENABLED=true
COMPLETION_FALLBACK_BASE_URL=http://127.0.0.1:11434/v1
COMPLETION_FALLBACK_MODEL=qwen2.5-coder:14b

# 如无特殊需要，embedding 继续保留本地
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMBEDDING_MODEL=nomic-embed-text:latest
